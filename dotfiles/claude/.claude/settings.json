{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(gh search:*)",
      "Bash(wl-copy)",
      "Bash(wl-paste)",
      "Bash(wl-paste --list-types)"
    ]
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash /home/stevenguido/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "theme": "dark-daltonized",
  "skipAutoPermissionPrompt": true,
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "bash /home/stevenguido/.claude/card-hook.sh turnstart" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "bash /home/stevenguido/.claude/card-hook.sh stop" } ] }
    ],
    "StopFailure": [
      { "hooks": [ { "type": "command", "command": "bash /home/stevenguido/.claude/card-hook.sh error" } ] }
    ],
    "PermissionRequest": [
      { "hooks": [ { "type": "command", "command": "bash /home/stevenguido/.claude/card-hook.sh permission" } ] }
    ],
    "Notification": [
      { "matcher": "idle_prompt", "hooks": [ { "type": "command", "command": "bash /home/stevenguido/.claude/card-hook.sh idle" } ] }
    ]
  }
}
